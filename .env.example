# MyAuthSystem Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# === DATABASE ===
# For local development (outside Docker)
DATABASE_URL=ecto://postgres:postgres@localhost:5432/my_auth_system_dev

# === PHOENIX ===
PHX_HOST=localhost
PHX_SERVER=true
PORT=4000

# === SECRETS ===
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=your-secret-key-base-change-this-min-64-chars

# Generate with: openssl rand -base64 32
GUARDIAN_SECRET_KEY=your-guardian-secret-change-this

# === EMAIL (BREVO) ===
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SENDER_NAME=MyAuth System
BREVO_SENDER_EMAIL=noreply@myauthsystem.com

# === APPLICATION ===
APP_URL=http://localhost:4000

# === RELEASE (for production/Docker) ===
RELEASE_NODE=my_auth_system@127.0.0.1
RELEASE_COOKIE=change-this-in-production
